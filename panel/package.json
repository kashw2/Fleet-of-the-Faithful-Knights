{
  "name": "@ffk/panel",
  "version": "1.0.0",
  "scripts": {
    "prebuild": "rimraf .angular",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "test": "ng test",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "docker:build": "docker build -t ghcr.io/kashw2/panel.faithfulknights.com:$(git rev-parse --verify HEAD) -t ghcr.io/kashw2/panel.faithfulknights.com:latest -f Dockerfile .",
    "docker:run": "docker run -p 4200:80 ghcr.io/kashw2/panel.faithfulknights.com:$(git rev-parse --verify HEAD)",
    "docker:publish": "docker push ghcr.io/kashw2/panel.faithfulknights.com:$(git rev-parse --verify HEAD) && docker push ghcr.io/kashw2/panel.faithfulknights.com:latest"
  },
  "dependencies": {
    "@angular/animations": "22.0.4",
    "@angular/cdk": "22.0.2",
    "@angular/common": "22.0.4",
    "@angular/compiler": "22.0.4",
    "@angular/core": "22.0.4",
    "@angular/forms": "22.0.4",
    "@angular/material": "22.0.2",
    "@angular/platform-browser": "22.0.4",
    "@angular/platform-browser-dynamic": "22.0.4",
    "@angular/router": "22.0.4",
    "@fortawesome/fontawesome-free": "7.3.0",
    "animate.css": "4.1.1",
    "ngx-toastr": "20.0.5",
    "rxjs": "7.8.2",
    "screenfull": "5.2.0",
    "tslib": "2.8.1",
    "zone.js": "0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "22.0.4",
    "@angular/cli": "22.0.4",
    "@angular/compiler-cli": "22.0.4",
    "@types/jasmine": "6.0.0",
    "@types/node": "26.0.1",
    "jasmine-core": "6.3.0",
    "jasmine-spec-reporter": "7.0.0",
    "karma": "6.4.4",
    "karma-chrome-launcher": "3.2.0",
    "karma-coverage": "2.2.1",
    "karma-firefox-launcher": "2.1.3",
    "karma-jasmine": "5.1.0",
    "karma-jasmine-html-reporter": "2.2.0",
    "ts-node": "10.9.2",
    "typescript": "6.0.3"
  },
  "browser": {
